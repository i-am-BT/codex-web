# Run `npm run setup` to generate a local .env, or copy this file manually.

APP_NAME=Codex Web Example

# Required. Password used to sign in to the Web UI.
CODEX_WEB_PASSWORD=<replace-with-a-strong-password>

# Local-only by default. Use 0.0.0.0 only behind a trusted LAN/firewall.
PORT=36354
HOST=127.0.0.1
PUBLIC_HOST=127.0.0.1
PORT_MIN=30000
PORT_MAX=39999

# Keep this stable so login sessions survive restarts.
SESSION_SECRET=<replace-with-at-least-32-random-bytes>
SESSION_TTL_HOURS=168
COOKIE_SECURE=false

# Optional. Enables the read-only Homepage statistics endpoint.
HOMEPAGE_API_TOKEN=<optional-random-read-only-api-token>
HOMEPAGE_MODEL_CACHE_SECONDS=60

# Optional. Shows CPA Codex quotas in the authenticated Web UI.
# Keep the real management key only in the local .env file.
SUB2API_BASE_URL=http://127.0.0.1:8327
SUB2API_API_KEY=
SUB_QUOTA_TIMEOUT_MS=10000
SUB_QUOTA_CACHE_SECONDS=30

# Image Prompt library updates from freestylefly/awesome-gpt-image-2.
IMAGE_PROMPT_AUTO_SYNC=true
IMAGE_PROMPT_SYNC_INTERVAL_MINUTES=360
IMAGE_PROMPT_SYNC_TIMEOUT_MS=20000
PLAYGROUND_PROXY_TIMEOUT_MS=300000
# Comma-separated origins allowed in addition to configured Codex Providers.
PLAYGROUND_PROXY_ALLOWED_ORIGINS=https://api.example.com
# Optional. Raises the GitHub API rate limit; keep the real token only in .env.
IMAGE_PROMPT_GITHUB_TOKEN=

# Host Codex CLI integration.
# `npm run setup` prefers the Codex binary bundled with ChatGPT/Codex App on macOS.
CODEX_BIN=/absolute/path/to/codex
CODEX_HOME=/home/<user>/.codex
CODEX_CONFIG_WRITABLE=false
CODEX_WEB_ENV_FILE=/absolute/path/to/codex-web/.env
CODEX_WEB_RUNTIME_DIR=/absolute/path/to/codex-web/runtime

# Bidirectional Codex App session synchronization.
APP_SERVER_REQUEST_TIMEOUT_MS=30000
# Prefer the currently open Codex App window for existing-thread turns.
CODEX_DESKTOP_IPC_ENABLED=true
CODEX_DESKTOP_IPC_TIMEOUT_MS=20000
# Optional override. Leave empty to use the current user's Codex Desktop socket.
CODEX_DESKTOP_IPC_SOCKET=
NATIVE_SESSION_MAX_READ_MB=32
NATIVE_SESSION_MAX_MESSAGES=700
NATIVE_SESSION_MAX_ITEMS=100
NATIVE_SESSION_POLL_MS=3000

# Defaults used when creating a new conversation.
DEFAULT_PROVIDER=
DEFAULT_MODEL=
DEFAULT_CWD=/absolute/path/to/<workspace>
DEFAULT_SANDBOX=workspace-write
DEFAULT_APPROVAL=on-request

# Emergency deployment policy. When true, the Web UI locks every task to
# danger-full-access with approval=never. Keep false for selectable permissions.
FORCE_FULL_ACCESS=false
