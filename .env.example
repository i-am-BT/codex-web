# Copy this file to .env and edit the values for your machine.

# Required. Password used to sign in to the Web UI.
CODEX_WEB_PASSWORD=change-this-password

# Optional. Fixed port for the Web server. Leave unset to choose a free port
# from PORT_MIN to PORT_MAX.
PORT=36354
HOST=0.0.0.0
PORT_MIN=30000
PORT_MAX=39999

# Optional. Set a stable value if you want login sessions to survive restarts.
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_HOURS=168

# Optional Codex defaults used when creating a new conversation.
DEFAULT_PROVIDER=
DEFAULT_MODEL=gpt-5.5
DEFAULT_CWD=/root
DEFAULT_SANDBOX=read-only
DEFAULT_APPROVAL=never
