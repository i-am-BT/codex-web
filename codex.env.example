# Copy values from this file into /root/.codex/.env on the machine that runs Codex Web.
# Do not commit the real /root/.codex/.env file.

# Example provider API keys. Keep only the keys you actually use.
OPENAI_API_KEY=replace-with-your-openai-api-key
CUSTOM_PROVIDER_API_KEY=replace-with-your-provider-api-key
