+  if (!text) return false
+
+  const chineseImageRequest = /(?:生成|创建|制作|设计|绘制|画|做).{0,24}(?:图片|图像|海报|插画|照片|封面|壁纸|头像|logo|图|画)|(?:图片|图像|海报|插画|照片|封面|壁纸|头像|logo).{0,24}(?:生成|创建|制作|设计|绘制|画|做)|生图/i
+  const englishImageRequest = /\b(?:generate|create|make|draw|design|render|illustrate)\b[\s\S]{0,80}\b(?:image|picture|poster|illustration|photo|wallpaper|cover|avatar|logo)\b|\b(?:image|picture|poster|illustration|photo|wallpaper|cover|avatar|logo)\b[\s\S]{0,80}\b(?:generate|create|make|draw|design|render|illustrate)\b/i
+  const referenceEditRequest = hasInputImages && /(?:修改|编辑|重做|重绘|变体|换成|改成|去掉|添加|美化|扩图|抠图)|\b(?:edit|change|modify|transform|replace|remove|add|retouch|extend)\b/i.test(text)
+  return chineseImageRequest.test(text) || englishImageRequest.test(text) || referenceEditRequest
+}
